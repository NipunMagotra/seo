{
  "manifest_version": 3,
  "name": "RankPilot — SEO & AI Scorer",
  "short_name": "RankPilot",
  "version": "1.0.0",
  "description": "Instant SEO & AI Search score for any webpage. Powered by RankPilot.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "RankPilot SEO & AI Score",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://api.allorigins.win/*",
    "https://corsproxy.io/*"
  ]
}
